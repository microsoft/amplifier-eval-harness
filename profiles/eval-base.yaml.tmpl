# eval-harness DTU profile template
#
# Rendered per-run by eval_harness.profile.render_profile().
# Splice points (literal placeholders below, marked with double braces):
#   URL_REWRITES_RULES        - one rule per repo we route through Gitea
#   PYPI_OVERRIDES            - inserted only when amplifier-core is locally overridden
#   SETTINGS_OVERLAY_FILES    - inserted only when settings_overlay is configured
#   SETTINGS_OVERLAY_SETUP_CMD - inserted only when settings_overlay is configured
#
# Resolved at LAUNCH time via amplifier-digital-twin --var KEY=VALUE:
#   GITEA_URL, GITEA_TOKEN, BUNDLE_INSTALL_URL, BUNDLE_REPO, BUNDLE_NAME,
#   SCENARIO_ID, AMPLIFIER_INSTALL_REF

name: eval-${BUNDLE_NAME}-${SCENARIO_ID}
description: >
  Eval run for bundle ${BUNDLE_NAME} (${BUNDLE_REPO}), scenario ${SCENARIO_ID}.

base:
  image: ubuntu:24.04

# ---- url_rewrites: redirect github.com -> Gitea ---------------------------
url_rewrites:
  auth:
    username: admin
    token_var: GITEA_TOKEN
  default_match_mode: boundary
  rules:
{{ URL_REWRITES_RULES }}

# ---- pypi_overrides (only when amplifier-core is locally overridden) ------
{{ PYPI_OVERRIDES }}

# ---- passthrough: forward provider API keys + base URLs from host ---------
# Listed env vars that are unset on the host are simply not forwarded.
#
# GITHUB_TOKEN was previously omitted (per amplifier-tester self-validation
# pattern) on the rationale that public microsoft/* repos clone anonymously
# and Gitea-rewritten URLs use url_rewrites.auth. That holds for cloning,
# but the github-copilot provider needs GITHUB_TOKEN for SDK session
# creation. Reinstated 2026-05-09 so per-provider repro tests can exercise
# github-copilot. Listed env vars that are unset on the host are simply
# not forwarded.
# (Earlier diagnostics in this harness wrongly attributed a 404 cascade
# to GH_TOKEN — the real cause was a prefix-collision bug in url_rewrites,
# not the token. See ALWAYS_MIRROR_REPOS in profile.py for the real fix.)
passthrough:
  allow_external: true
  services:
    - name: anthropic-key
      key_env: ANTHROPIC_API_KEY
    - name: anthropic-base-url
      key_env: ANTHROPIC_BASE_URL
    - name: openai-key
      key_env: OPENAI_API_KEY
    - name: openai-base-url
      key_env: OPENAI_BASE_URL
    - name: azure-openai-key
      key_env: AZURE_OPENAI_API_KEY
    - name: google-key
      key_env: GOOGLE_API_KEY
    - name: github-token
      key_env: GITHUB_TOKEN

# ---- provision: install amplifier + bundle, optionally merge settings -----
provision:
{{ SETTINGS_OVERLAY_FILES }}
  setup_cmds:
    # 1. System deps + uv installer.
    #    pytest + python3-pip are pre-installed so test/refactor/fix scenarios
    #    can run pytest directly without each prompt having to bootstrap them.
    # python3-yaml is required by the settings-overlay merge (step 4) and the
    # force-raw injection (step 4b); --no-install-recommends would otherwise
    # leave PyYAML out of the system Python.
    - apt-get update && apt-get install -y --no-install-recommends
        git curl ca-certificates
        python3 python3-pip python3-pytest python3-yaml
    - curl -LsSf https://astral.sh/uv/install.sh | sh

    # 2. Install amplifier from upstream (intercepted by mitmproxy and redirected to Gitea)
    - |
      export PATH="/root/.local/bin:$PATH"
      uv tool install git+https://github.com/microsoft/amplifier@${AMPLIFIER_INSTALL_REF}

    # 3. Write empty settings.yaml stub (will be deep-merged with overlay if configured)
    - |
      mkdir -p /root/.amplifier
      if [ ! -f /root/.amplifier/settings.yaml ]; then
        cat > /root/.amplifier/settings.yaml << 'EOF'
      # Placeholder - deep-merged with settings_overlay (if any) in the next step.
      EOF
      fi

    # 4. Optional: deep-merge settings overlay if one was provided
{{ SETTINGS_OVERLAY_SETUP_CMD }}

    # 4b. Force session.raw=true so the kernel logs the resolved mount plan.
    #
    # Without session.raw=true the kernel emits only {session_id, parent_id, timestamp}
    # at session:start. With it, a SECOND session:start event carries the
    # redacted post-overlay mount plan in data.raw — this is what makes
    # mount-plan extraction from events.jsonl possible, regardless of what
    # the test bundle declares.
    #
    # Wired via a tiny "force-raw" behavior bundle composed through bundle.app.
    # Bundle.compose() deep-merges session blocks with later-wins precedence
    # (amplifier-foundation bundle/_dataclass.py:226-227), so this always wins
    # over the test bundle's session.raw value (if any). This step is harness
    # machinery and runs on every invocation.
    - |
      mkdir -p /root/.amplifier/behaviors
      cat > /root/.amplifier/behaviors/force-raw.yaml << 'EOF'
      ---
      bundle:
        name: force-raw
        version: 1.0.0
        description: Eval-harness overlay that forces session.raw=true so the resolved mount plan is logged.

      session:
        raw: true
      EOF
      python3 - << 'PYEOF'
      import yaml
      from pathlib import Path
      p = Path("/root/.amplifier/settings.yaml")
      data = yaml.safe_load(p.read_text()) if p.exists() else {}
      if not isinstance(data, dict):
          data = {}
      bundle = data.setdefault("bundle", {})
      if not isinstance(bundle, dict):
          bundle = {}
          data["bundle"] = bundle
      app = bundle.get("app")
      if not isinstance(app, list):
          app = []
      uri = "file:///root/.amplifier/behaviors/force-raw.yaml"
      if uri not in app:
          app.append(uri)
      bundle["app"] = app
      p.parent.mkdir(parents=True, exist_ok=True)
      p.write_text(yaml.safe_dump(data, default_flow_style=False, sort_keys=False))
      print(f"force-raw wired via bundle.app: {uri}")
      PYEOF

    # 5. Add the bundle under test (no --app: standalone bundle, project-local).
    #    BUNDLE_INSTALL_URL preserves any subdirectory fragment from the source.
    - |
      export PATH="/root/.local/bin:$PATH"
      mkdir -p /workspace
      cd /workspace
      amplifier bundle add ${BUNDLE_INSTALL_URL} --name ${BUNDLE_NAME}
      amplifier bundle use ${BUNDLE_NAME}

    # 6. Sanity checks
    - export PATH="/root/.local/bin:$PATH" && amplifier --version
    - export PATH="/root/.local/bin:$PATH" && cd /workspace && amplifier bundle current

# ---- update: optional, not used per-run; left here for manual debug -------
update:
  cmds:
    - |
      export PATH="/root/.local/bin:$PATH"
      amplifier update --yes --force

# ---- readiness: gate launch on amplifier being functional -----------------
readiness:
  - name: amplifier-installed
    type: command
    command: 'export PATH=/root/.local/bin:$PATH && amplifier --version'
  - name: bundle-active
    type: command
    command: 'export PATH=/root/.local/bin:$PATH && cd /workspace && amplifier bundle current | grep -q .'
